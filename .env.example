# =============================================================================
# TypeScript Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Use Neon, Supabase, or local PostgreSQL
DATABASE_URL=postgresql://username:password@localhost:5432/dbname?sslmode=require

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# -----------------------------------------------------------------------------
# Options: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# AUTH0 CONFIGURATION
# -----------------------------------------------------------------------------
# Get these from your Auth0 Dashboard → Applications → APIs
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_AUDIENCE=https://your-domain.auth0.com/api/v2/
AUTH0_ISSUER=https://your-domain.auth0.com/
AUTH0_JWKS_URI=https://your-domain.auth0.com/.well-known/jwks.json

# -----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# -----------------------------------------------------------------------------
# Request timestamp window for replay protection (seconds)
AUTH_REQUEST_TIMESTAMP_WINDOW_SECONDS=300

# CORS whitelist (comma-separated origins)
CORS_WHITELIST=http://localhost:3000,http://localhost:3001

# Maximum request body size
MAX_BODY_SIZE=10kb

# JWT secret for internal tokens (if needed)
JWT_SECRET=some_very_long_random_secret_string_here_at_least_32_characters

# -----------------------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# -----------------------------------------------------------------------------
# Auth endpoints rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=900000        # 15 minutes
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# Chat endpoints rate limiting
RATE_LIMIT_CHAT_WINDOW_MS=60000          # 1 minute
RATE_LIMIT_CHAT_MAX_REQUESTS_IP=100       # Per IP
RATE_LIMIT_CHAT_MAX_REQUESTS_USER=30      # Per authenticated user

# Subscription endpoints rate limiting
RATE_LIMIT_SUBSCRIPTIONS_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_SUBSCRIPTIONS_MAX_REQUESTS=20  # Per user/IP

# -----------------------------------------------------------------------------
# DEVELOPMENT OPTIONS
# -----------------------------------------------------------------------------
# Enable database synchronization (dev only)
DB_SYNCHRONIZE=false

# Enable database query logging
DB_LOGGING=false

# -----------------------------------------------------------------------------
# TESTING CONFIGURATION
# -----------------------------------------------------------------------------
# Test database URL (optional - defaults to in-memory SQLite)
TEST_DATABASE_URL=sqlite::memory:

# Test Auth0 settings (for mocking)
TEST_AUTH0_DOMAIN=test.auth0.com
TEST_AUTH0_AUDIENCE=https://test.auth0.com/api/v2/

# =============================================================================
# QUICK SETUP GUIDE
# =============================================================================
#
# 1. Auth0 Setup:
#    - Create account at https://auth0.com
#    - Create Machine-to-Machine application
#    - Create API with identifier matching AUTH0_AUDIENCE
#    - Enable RBAC and add permissions to tokens
#    - Add roles using Auth0 Actions (see README.md)
#
# 2. Database Setup:
#    - Option A: Local PostgreSQL
#      createdb your_db_name
#    - Option B: Neon (recommended)
#      Sign up at https://neon.tech and copy connection string
#
# 3. Run Application:
#    npm install
#    npm run migration:run
#    npm run dev
#
# 4. Test Setup:
#    curl http://localhost:3000/health
#
# =============================================================================